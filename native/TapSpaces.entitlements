<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Hardened Runtime is required for notarisation, and it blocks microphone
      access unless this entitlement is present.

      Deliberately NOT sandboxed: the app posts synthetic key events to other
      applications, and no sandbox entitlement permits that. This is also why
      it ships outside the Mac App Store.
    -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
